---
// Layout.astro — the shared wrapper for every page.
// The `---` fences are the "frontmatter" block: this is where you write
// TypeScript/JavaScript that runs at build time (not in the browser).
// Props let pages pass data in — here, just the page title.
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Most security engineers can't write. Most technical writers can't build. I do both." } = Astro.props;
const ogTitle = title === 'Home' ? 'Megan Barker' : `${title} | Megan Barker`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Megan Barker" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Megan Barker" />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <title>{title} | Megan Barker</title>

  </head>

  <body class="bg-white text-slate-800 antialiased">

    <!-- Nav -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm">
      <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-mono text-sm font-medium text-slate-900 hover:text-blue-600 transition-colors whitespace-nowrap">
          <span class="inline-block w-2 h-2 rounded-sm bg-blue-600 shrink-0"></span>
          megan barker
        </a>
        <!-- Desktop nav -->
        <ul class="hidden sm:flex items-center gap-8 text-sm font-medium text-slate-500">
          <li><a href="/writing" class="hover:text-slate-900 transition-colors">Writing</a></li>
          <li><a href="/engineering" class="hover:text-slate-900 transition-colors">Engineering</a></li>
          <li><a href="/about" class="hover:text-slate-900 transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-slate-900 transition-colors">Blog</a></li>
        </ul>
        <!-- Mobile hamburger -->
        <button id="menu-toggle" class="sm:hidden p-2 text-slate-500 hover:text-slate-900 transition-colors" aria-label="Toggle menu">
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="hidden">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden sm:hidden bg-white/95 border-t border-slate-100">
        <ul class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4 text-sm font-medium text-slate-500">
          <li><a href="/writing" class="hover:text-slate-900 transition-colors">Writing</a></li>
          <li><a href="/engineering" class="hover:text-slate-900 transition-colors">Engineering</a></li>
          <li><a href="/about" class="hover:text-slate-900 transition-colors">About</a></li>
          <li><a href="/blog" class="hover:text-slate-900 transition-colors">Blog</a></li>
        </ul>
      </div>
      <div class="h-px bg-gradient-to-r from-blue-600 via-blue-400 to-amber-400 opacity-50"></div>
    </header>

    <script src="/nav.js" defer is:inline></script>

    <!-- Page content is slotted in here — <slot /> is Astro's version of {children} in React -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-100 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-400">
        <span>© {new Date().getFullYear()} Megan Barker</span>
        <a href="mailto:&#109;&#101;&#64;&#109;&#101;&#103;&#97;&#110;&#98;&#97;&#114;&#107;&#101;&#114;&#46;&#99;&#97;" class="hover:text-blue-600 transition-colors">Email me</a>
      </div>
    </footer>

  </body>
</html>

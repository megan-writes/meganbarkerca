---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { title, description, pubDate, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description}>

  <!-- Post header -->
  <div class="bg-slate-900 text-white border-b border-slate-800">
    <div class="max-w-3xl mx-auto px-6 py-16">
      <div class="flex items-center gap-3 mb-4">
        <a href="/blog" class="font-mono text-xs text-amber-400 uppercase tracking-widest hover:text-amber-300 transition-colors">Blog</a>
        {tags.length > 0 && (
          <>
            <span class="text-slate-700">/</span>
            <div class="flex gap-2">
              {tags.map(tag => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="font-mono text-xs text-slate-400 hover:text-slate-200 transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          </>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 leading-tight">{title}</h1>
      <time class="font-mono text-xs text-slate-500" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
    </div>
  </div>

  <!-- Post content -->
  <div class="max-w-3xl mx-auto px-6 py-16">
    <div class="prose">
      <slot />
    </div>

    <!-- Back link -->
    <div class="mt-16 pt-8 border-t border-slate-100">
      <a href="/blog" class="font-mono text-sm text-slate-400 hover:text-slate-900 transition-colors">← Back to blog</a>
    </div>
  </div>

</Layout>

<style>
  .prose {
    color: #475569; /* slate-600 */
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  .prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose :global(p) {
    margin-bottom: 1.5rem;
  }
  .prose :global(a) {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a:hover) {
    color: #1d4ed8;
  }
  .prose :global(strong) {
    color: #1e293b;
    font-weight: 600;
  }
  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: #f1f5f9;
    color: #0f172a;
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }
  .prose :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875rem;
    line-height: 1.7;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .prose :global(ul) { list-style-type: disc; }
  .prose :global(ol) { list-style-type: decimal; }
  .prose :global(li) {
    margin-bottom: 0.4rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid #2563eb;
    padding-left: 1.25rem;
    color: #64748b;
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 2rem 0;
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404" description="Page not found.">

  <div class="bg-slate-900 text-white border-b border-slate-800">
    <div class="max-w-5xl mx-auto px-6 py-16">
      <p class="font-mono text-xs text-amber-400 uppercase tracking-widest mb-3">404</p>
      <h1 class="text-4xl font-bold mb-4">Not ideal</h1>
      <p class="text-lg text-slate-400 max-w-2xl">
        I built this page intentionally but can't account for how you ended up here. Awkward.
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-20">
    <p class="text-slate-600 mb-8">Let's get you somewhere more interesting.</p>
    <div class="flex flex-wrap gap-4">
      <a href="/" class="bg-slate-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-slate-700 transition-colors">
        Go home
      </a>
      <a href="/writing" class="border border-slate-200 text-slate-600 px-6 py-3 rounded-lg font-medium hover:border-slate-400 hover:text-slate-900 transition-colors">
        Read what I write
      </a>
      <a href="/engineering" class="border border-slate-200 text-slate-600 px-6 py-3 rounded-lg font-medium hover:border-slate-400 hover:text-slate-900 transition-colors">
        See what I build
      </a>
    </div>
  </div>

</Layout>

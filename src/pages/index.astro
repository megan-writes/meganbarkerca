---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- Hero -->
  <section class="relative min-h-[92vh] flex items-center bg-slate-900 text-white overflow-hidden">
    <!-- Grid texture -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <!-- Blue glow -->
    <div class="absolute bottom-0 left-0 w-[600px] h-[400px] bg-blue-600/10 rounded-full blur-3xl"></div>
    <!-- Amber glow -->
    <div class="absolute top-0 right-0 w-[400px] h-[300px] bg-amber-500/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-5xl mx-auto px-6 py-24">

      <!-- Pseudocode block -->
      <div class="font-mono text-sm text-slate-400 mb-10 space-y-1">
        <p><span class="text-blue-400">const</span> <span class="text-white">megan</span> <span class="text-slate-400">=</span> <span class="text-slate-300">&#123;</span></p>
        <p class="pl-6"><span class="text-emerald-400">role</span><span class="text-slate-400">:</span> <span class="text-amber-300">"security engineer"</span><span class="text-slate-400">,</span></p>
        <p class="pl-6"><span class="text-emerald-400">also</span><span class="text-slate-400">:</span> <span class="text-amber-300">"technical writer"</span><span class="text-slate-400">,</span></p>
        <p class="pl-6"><span class="text-emerald-400">domain</span><span class="text-slate-400">:</span> <span class="text-amber-300">"SaaS security, privacy &amp; compliance"</span><span class="text-slate-400">,</span></p>
        <p class="pl-6"><span class="text-emerald-400">superpower</span><span class="text-slate-400">:</span> <span class="text-amber-300">"technical depth + clear prose"</span></p>
        <p><span class="text-slate-300">&#125;</span></p>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6">
        Security engineer.<br />
        Technical writer.
      </h1>
      <p class="text-lg sm:text-xl text-slate-300 max-w-2xl leading-relaxed mb-10">
        Most security engineers can't write. Most technical writers can't build. I can do both.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/engineering" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-500 transition-colors">
          Engineering work
        </a>
        <a href="/writing" class="border border-slate-600 text-slate-200 px-6 py-3 rounded-lg font-medium hover:border-slate-400 hover:text-white transition-colors">
          Writing portfolio
        </a>
      </div>

    </div>
  </section>


</Layout>
